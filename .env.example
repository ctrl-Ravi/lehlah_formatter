# ──────────────────────────────────────────────
# Deal Formatter Bot – Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# Required: Your Telegram Bot API token from @BotFather
BOT_TOKEN=your_bot_token_here

# Optional: Comma-separated Telegram user IDs for admin access
# Example: ADMIN_IDS=123456789,987654321
ADMIN_IDS=

# Optional: The port for the keep-alive web server to run on (defaults to 8080)
# Note: Render automatically provides this variable in production.
PORT=8080

# Optional: The external URL of your web service, used for self-pinging to stay awake.
# Note: Render automatically provides this variable in production.
RENDER_EXTERNAL_URL=
